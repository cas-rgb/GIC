rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAnalyst() {
      return hasRole('analyst') || isAdmin();
    }

    function isExecutive() {
      return hasRole('executive') || isAnalyst();
    }

    // Collection Rules
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /community_signals/{signalId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /community_sentiment/{sentimentId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /influencers/{influencerId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /infrastructure_predictions/{predId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /community_priority_scores/{scoreId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /project_sites/{projectId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /project_risk_forecasts/{riskId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    match /engagement_recommendations/{recId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    // GIC Government Pulse Collections
    match /gic_projects/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    match /riskSignals/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    match /planningBudgets/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    match /news_articles/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    match /strategicDatasets/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }
    
    match /leadership/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    match /universal_signals/{id} {
      allow read: if true;
      allow write: if isAnalyst();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
  }
}
