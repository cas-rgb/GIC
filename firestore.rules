rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserTenantId() {
      return request.auth.token.tenantId != null ? request.auth.token.tenantId : 'gic_national_gov';
    }

    function isTenantMatch() {
      return !('tenantId' in resource.data) || resource.data.tenantId == getUserTenantId();
    }
    
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAnalyst() {
      return hasRole('analyst') || isAdmin();
    }

    function isExecutive() {
      return hasRole('executive') || isAnalyst();
    }

    // Collection Rules
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /community_signals/{signalId} {
      allow read: if isExecutive();
      allow write: if isAnalyst();
    }

    // Core Pulse Collections
    match /gic_projects/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }

    match /riskSignals/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }

    match /planningBudgets/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }

    match /news_articles/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }

    match /strategicDatasets/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }
    
    match /leadership/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }

    match /universal_signals/{id} {
      allow read: if isAuthenticated() && isTenantMatch();
      allow write: if isAnalyst() && isTenantMatch();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
  }
}
